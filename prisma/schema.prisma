// ChronoFlow — dynamic AI calendar/task manager
// Authoritative data model. See CLAUDE.md for architectural guardrails.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts (Prisma 7 requirement).
}

// ---------- Auth.js v5 default tables ----------
// Required shape for @auth/prisma-adapter. Do not rename fields.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  timezone      String    @default("America/New_York")

  accounts         Account[]
  sessions         Session[]
  constraints      Constraint[]
  tasks            Task[]
  timeBlocks       TimeBlock[]
  scheduleVersions ScheduleVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- ChronoFlow domain ----------

enum ConstraintType {
  SLEEP
  MEAL
  HYGIENE
  CUSTOM
}

enum Priority {
  P0
  P1
  P2
  P3
}

enum TimeOfDay {
  ANY
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

enum EnergyType {
  HIGH
  LOW
  CREATIVE
  ADMIN
}

enum TaskStatus {
  PENDING
  SCHEDULED
  DONE
  DEFERRED
}

enum BlockSource {
  GCAL
  AI
  MANUAL
  BUFFER
}

enum BlockStatus {
  PLANNED
  IN_PROGRESS
  DONE
  SKIPPED
}

enum GeneratedBy {
  FULL_WEEK
  PARTIAL_48H
  CHECKIN
  NIGHTLY_REVIEW
}

enum CheckInOutcome {
  ON_TIME
  EARLY
  LATE
  SKIPPED
}

// A user constraint: recurring block of time that is unavailable or has a cost.
// `schedule` is serialized as JSON — either {startMinuteOfDay, endMinuteOfDay, daysOfWeek[]}
// or an iCal-style RRULE string, depending on the complexity we need. Kept as Json for flexibility.
model Constraint {
  id         String         @id @default(cuid())
  userId     String
  type       ConstraintType
  label      String
  schedule   Json
  energyCost Int            @default(0) // 0 = no drain; higher values bias the AI to avoid adjacency

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A user-requested piece of work to be scheduled.
model Task {
  id                 String     @id @default(cuid())
  userId             String
  title              String
  estimatedMinutes   Int
  completedMinutes   Int        @default(0)
  priority           Priority   @default(P2)
  preferredTimeOfDay TimeOfDay  @default(ANY)
  // Optional weekday preference. [] means no preference; [1,3,5] = Mon/Wed/Fri.
  // 0 = Sunday, 6 = Saturday. Consumed by the Gemini prompt as a soft bias.
  preferredDaysOfWeek Int[]     @default([])
  energyType         EnergyType @default(ADMIN)
  deadline           DateTime?
  status             TaskStatus @default(PENDING)
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeBlocks TimeBlock[]

  @@index([userId, status])
  @@index([userId, priority])
}

// Unified calendar event: GCal-imported, AI-scheduled, manually added, or buffer.
// TimeBlock is the SINGLE SOURCE OF TRUTH for "what's on the calendar".
model TimeBlock {
  id       String      @id @default(cuid())
  userId   String
  taskId   String?
  source   BlockSource
  start    DateTime
  end      DateTime
  title    String
  status   BlockStatus @default(PLANNED)
  metadata Json? // source-specific extras: gcal event id, energyType, buffer kind, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  checkIns CheckIn[]

  @@index([userId, start])
  @@index([userId, source])
  @@index([taskId])
}

// Immutable snapshot of a user's schedule, taken whenever the AI mutates state.
// Used by the Diff View: we compare the proposed `snapshot` against the current
// `TimeBlock` rows (or against the previous ScheduleVersion) to render green/red/yellow.
model ScheduleVersion {
  id          String      @id @default(cuid())
  userId      String
  generatedBy GeneratedBy
  snapshot    Json // array of TimeBlock-shaped objects
  approved    Boolean     @default(false) // false = proposal awaiting Diff View approval
  notes       String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// End-of-block user report. Used to trigger partial reflows.
model CheckIn {
  id            String         @id @default(cuid())
  timeBlockId   String
  outcome       CheckInOutcome
  actualMinutes Int? // reported actual duration; null if SKIPPED
  extraMinutes  Int? // populated when outcome=LATE
  note          String?

  createdAt DateTime @default(now())

  timeBlock TimeBlock @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)

  @@index([timeBlockId])
}
